<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Migrate update_date from varchar2 to timestamp(6) on all tables that still have varchar2 -->
    <!-- financial_transactions already uses timestamp(6) so it is excluded -->

    <changeSet id="014-1" author="opera-cloud">
        <modifyDataType tableName="name" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-2" author="opera-cloud">
        <modifyDataType tableName="membership" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-3" author="opera-cloud">
        <modifyDataType tableName="name_address" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-4" author="opera-cloud">
        <modifyDataType tableName="name_phone" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-5" author="opera-cloud">
        <modifyDataType tableName="reservation_name" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-6" author="opera-cloud">
        <modifyDataType tableName="reservation_daily_elements" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-7" author="opera-cloud">
        <modifyDataType tableName="reservation_daily_element_name" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-8" author="opera-cloud">
        <modifyDataType tableName="reservation_special_requests" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-9" author="opera-cloud">
        <modifyDataType tableName="ar_account" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-10" author="opera-cloud">
        <modifyDataType tableName="folio_tax" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-11" author="opera-cloud">
        <modifyDataType tableName="trx_codes" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <changeSet id="014-12" author="opera-cloud">
        <modifyDataType tableName="rate_header" columnName="update_date" newDataType="timestamp(6)"/>
    </changeSet>

    <!-- Indexes on update_date for all 13 tables -->

    <changeSet id="014-idx-1" author="opera-cloud">
        <createIndex tableName="name" indexName="idx_name_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-2" author="opera-cloud">
        <createIndex tableName="membership" indexName="idx_membership_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-3" author="opera-cloud">
        <createIndex tableName="name_address" indexName="idx_name_address_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-4" author="opera-cloud">
        <createIndex tableName="name_phone" indexName="idx_name_phone_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-5" author="opera-cloud">
        <createIndex tableName="reservation_name" indexName="idx_resv_name_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-6" author="opera-cloud">
        <createIndex tableName="reservation_daily_elements" indexName="idx_rde_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-7" author="opera-cloud">
        <createIndex tableName="reservation_daily_element_name" indexName="idx_rden_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-8" author="opera-cloud">
        <createIndex tableName="reservation_special_requests" indexName="idx_rsr_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-9" author="opera-cloud">
        <createIndex tableName="financial_transactions" indexName="idx_fin_trx_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-10" author="opera-cloud">
        <createIndex tableName="ar_account" indexName="idx_ar_account_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-11" author="opera-cloud">
        <createIndex tableName="folio_tax" indexName="idx_folio_tax_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-12" author="opera-cloud">
        <createIndex tableName="trx_codes" indexName="idx_trx_codes_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

    <changeSet id="014-idx-13" author="opera-cloud">
        <createIndex tableName="rate_header" indexName="idx_rate_header_update_date">
            <column name="update_date"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
